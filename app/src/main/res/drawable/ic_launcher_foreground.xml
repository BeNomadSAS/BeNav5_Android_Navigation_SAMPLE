<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground: the brand app-mark centered within the 108dp safe zone so launcher
     masks never clip it. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="60dp"
        android:height="60dp"
        android:drawable="@drawable/appicon"
        android:gravity="center" />
</layer-list>
