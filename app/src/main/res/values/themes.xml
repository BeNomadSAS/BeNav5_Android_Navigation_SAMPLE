<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Window theme applied before Compose takes over. No ActionBar; transparent
         system bars so the Compose content can draw edge-to-edge. -->
    <style name="Theme.BeNomadSample" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
