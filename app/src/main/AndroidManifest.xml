<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Mandatory: no mSDK module declares INTERNET. Needed for the license/LBO call,
         online autocomplete search, and hybrid map-tile streaming. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Real device GPS for the user position, map tracking and turn-by-turn guidance. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Foreground service keeps location flowing while guidance runs in the background. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:ignore="ForegroundServicesPolicy" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Runtime permission (Android 13+) for the guidance foreground-service notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Legacy license hardware-id on Android <= 9 only; harmless to declare. -->
    <uses-permission
        android:name="android.permission.READ_PHONE_STATE"
        android:maxSdkVersion="28" />

    <!-- NOTE: ACCESS_WIFI_STATE / CHANGE_WIFI_STATE / ACCESS_NETWORK_STATE are merged in
         from the Core AAR, and com.benomad.msdk.navigation.notification.LocationForegroundService
         is merged in from the Navigation AAR — do NOT redeclare them here. -->

    <application
        android:name=".SampleApp"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BeNomadSample">

        <!--
            configChanges: handle these configuration changes (rotation above all) IN-PLACE instead
            of letting Android recreate the Activity. This works around a crash we observed (it is not
            documented by the SDK): the map is a native GL view, and letting Android recreate it
            mid-guidance races the engine's background guidance thread against the view's destruction
            (we saw a SIGSEGV in CBHLGuidance::UpdateView / CBView::GetRenderer when rotating right as
            a session starts). Keeping the Activity (and
            the MapView) alive across rotation avoids that race and preserves the map camera, the
            route polyline, the markers and the running guidance session. Compose still recomposes on
            the configuration change, so orientation-dependent layouts (e.g. the route preview's
            portrait/landscape split) update correctly.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|locale|layoutDirection|uiMode|density|fontScale"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Task-removal sentinel: receives onTaskRemoved when the app is swiped from recents
             during guidance, to stop the native session (the SDK's foreground service does not).
             android:stopWithTask="false" is required for onTaskRemoved to be delivered. -->
        <service
            android:name=".guidance.GuidanceLifecycleService"
            android:exported="false"
            android:stopWithTask="false" />
    </application>
</manifest>
